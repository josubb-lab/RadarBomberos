---
import Layout from '../layouts/Layout.astro'
import { createClient } from '@supabase/supabase-js'
import { hallazgoSlug } from '../lib/slugify'
import { nicho, nichoId } from '../lib/nicho'
import { incidencias } from '../data/incidencias'

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_KEY,
)

const { data: hallazgos, error } = await supabase
  .from('hallazgos')
  .select('id, titulo, descripcion, fuente, fecha, url, tipo')
  .eq('nicho', nichoId)
  .gte('relevancia', 2)
  .or('fecha.gte.2020-01-01,curado.eq.true')
  .order('fecha', { ascending: false, nullsFirst: false })
  .limit(500)

const { data: statsData } = await supabase
  .from('hallazgos')
  .select('tipo')
  .eq('nicho', nichoId)
  .in('tipo', ['sentencia', 'impugnacion', 'anulacion'])
  .or('fecha.gte.2020-01-01,curado.eq.true')

const total              = hallazgos?.length ?? 0
const statsSentencias    = statsData?.filter(r => r.tipo === 'sentencia').length   ?? 0
const statsImpugnaciones = statsData?.filter(r => r.tipo === 'impugnacion').length ?? 0
const statsAnulaciones   = statsData?.filter(r => r.tipo === 'anulacion').length   ?? 0


const SOURCE_META: Record<string, { label: string; icon: string; color: string }> = {
  'BOE':                     { label: 'Boletín oficial', icon: '📋', color: 'text-amber-400 bg-amber-950/60 ring-amber-700/50' },
  'CENDOJ':                  { label: 'Sentencia',       icon: '⚖️',  color: 'text-rose-400 bg-rose-950/60 ring-rose-700/50'  },
  'CENDOJ (vía DuckDuckGo)': { label: 'Sentencia',       icon: '⚖️',  color: 'text-rose-400 bg-rose-950/60 ring-rose-700/50'  },
  'Google News':             { label: 'Prensa',           icon: '📰',  color: 'text-sky-400 bg-sky-950/60 ring-sky-700/50'     },
  'Google News (legal)':     { label: 'Sentencia',        icon: '⚖️',  color: 'text-rose-400 bg-rose-950/60 ring-rose-700/50'  },
}
function sourceMeta(fuente: string) {
  if (fuente.startsWith('Reddit')) return { label: 'Foro', icon: '💬', color: 'text-orange-400 bg-orange-950/60 ring-orange-700/50' }
  return SOURCE_META[fuente] ?? { label: fuente ?? 'Fuente', icon: '🔗', color: 'text-slate-400 bg-slate-800 ring-slate-700/50' }
}

const TIPO_INCIDENCIA: Record<string, string> = {
  sentencia:               'Sentencia',
  impugnacion:             'Impugnación',
  anulacion:               'Anulación',
  correccion_convocatoria: 'Corrección',
  recurso:                 'Recurso',
  pregunta_anulada:        'Pregunta anulada',
}

const serialized = JSON.stringify(
  (hallazgos ?? []).map(h => ({
    slug:        hallazgoSlug(h.titulo ?? '', h.id),
    titulo:      h.titulo      ?? '',
    descripcion: h.descripcion ?? '',
    fuente:      h.fuente      ?? '',
    fecha:       h.fecha       ?? null,
    url:         h.url         ?? '',
  }))
)

const TIPOS_JURIDICOS = new Set([
  'sentencia', 'impugnacion', 'anulacion', 'suspension', 'medida_cautelar', 'recurso', 'correccion_bases',
])
const recientes = (hallazgos ?? [])
  .filter(h => TIPOS_JURIDICOS.has(h.tipo ?? ''))
  .slice(0, 20)

const jsonLd = {
  '@context': 'https://schema.org',
  '@type':    'WebSite',
  name:        nicho.nombre,
  url:         nicho.siteUrl,
  description: nicho.seoDesc,
  inLanguage:  'es',
  publisher:   { '@type': 'Organization', name: nicho.nombre, url: nicho.siteUrl },
}
---

<Layout title={nicho.seoTitle} description={nicho.seoDesc} {jsonLd} canonical={nicho.siteUrl + '/'}>

  <!-- NAV -->
  <nav class="border-b border-slate-800 bg-slate-950/90 backdrop-blur sticky top-0 z-40">
    <div class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-semibold tracking-tight text-slate-100">
        <span class="text-amber-500 text-lg">⬡</span>
        {nicho.nombre}
      </a>
      <div class="flex items-center gap-5 text-xs text-slate-500">
        <a href="/oposiciones"  class="hover:text-slate-300 transition-colors hidden sm:block">Oposiciones</a>
        <a href="/incidencias"  class="hover:text-slate-300 transition-colors hidden sm:block">Observatorio</a>
        <a href="/origen-datos" class="hover:text-slate-300 transition-colors hidden sm:block">Fuentes</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="bg-gradient-to-b from-slate-900 to-slate-950 border-b border-slate-800/60">
    <div class="max-w-4xl mx-auto px-4 py-10 lg:py-12 text-center">
      <p class="text-amber-500 text-xs font-semibold uppercase tracking-widest mb-4">
        {nicho.tagline}
      </p>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-50 leading-tight mb-3">
        Oposiciones a bombero en España
      </h1>
      <p class="text-slate-400 text-base max-w-xl mx-auto">
        Convocatorias, procesos activos y señales jurídicas documentadas desde fuentes públicas.
      </p>
    </div>
  </section>

  <!-- DOS ENTRADAS PRINCIPALES -->
  <section class="border-b border-slate-800/60 bg-slate-950">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="grid sm:grid-cols-2 gap-4">

        <!-- Línea 1: Oposiciones -->
        <a href="/oposiciones"
           class="group rounded-xl border border-slate-700 bg-slate-900/60 p-6
                  hover:border-sky-700/60 hover:bg-sky-950/20 transition-colors block">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xl">🗂</span>
            <h2 class="text-base font-bold text-slate-100 group-hover:text-sky-300 transition-colors">
              Oposiciones
            </h2>
          </div>
          <p class="text-sm text-slate-400 mb-4 leading-relaxed">
            Guía de los 20 cuerpos de bomberos más importantes. Requisitos, temario y alertas de convocatoria.
          </p>
          <ul class="text-xs text-slate-500 space-y-1.5 mb-5">
            <li>· Requisitos de acceso por cuerpo</li>
            <li>· Fases del proceso selectivo</li>
            <li>· Alerta cuando convoquen en tu ciudad</li>
          </ul>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-sky-400 group-hover:text-sky-300 transition-colors">
            Ver oposiciones por ciudad
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </span>
        </a>

        <!-- Línea 2: Observatorio -->
        <a href="/incidencias"
           class="group rounded-xl border border-slate-700 bg-slate-900/60 p-6
                  hover:border-amber-700/60 hover:bg-amber-950/20 transition-colors block">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xl">⚖️</span>
            <h2 class="text-base font-bold text-slate-100 group-hover:text-amber-300 transition-colors">
              Observatorio jurídico
            </h2>
          </div>
          <p class="text-sm text-slate-400 mb-4 leading-relaxed">
            Sentencias, impugnaciones y anulaciones en oposiciones a bombero.
          </p>
          <ul class="text-xs text-slate-500 space-y-1.5 mb-5">
            <li>· <span class="text-rose-400 font-medium">{statsSentencias}</span> sentencias documentadas</li>
            <li>· <span class="text-amber-400 font-medium">{statsImpugnaciones}</span> impugnaciones registradas</li>
            <li>· <span class="text-slate-300 font-medium">{statsAnulaciones}</span> anulaciones verificadas</li>
          </ul>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-400 group-hover:text-amber-300 transition-colors">
            Ver observatorio jurídico
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </span>
        </a>

      </div>
    </div>
  </section>

  <!-- BUSCADOR -->
  <section class="border-b border-slate-800/60 bg-slate-900/30">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <p class="text-xs text-slate-500 mb-3">Buscar en el observatorio</p>
      <div class="relative max-w-xl">
        <button
          id="search-btn"
          type="button"
          aria-label="Buscar"
          class="absolute left-3 top-1/2 -translate-y-1/2 p-1 text-slate-500 hover:text-amber-400 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
        <input
          id="search-input"
          type="search"
          placeholder={nicho.placeholder}
          autocomplete="off"
          class="w-full bg-slate-800 border border-slate-600 rounded-xl pl-12 pr-4 py-4
                 text-base text-slate-100 placeholder-slate-500
                 focus:outline-none focus:ring-2 focus:ring-amber-500/60 focus:border-amber-500/60
                 transition shadow-lg shadow-black/30"
        />
      </div>
      <p id="search-stats" class="mt-2 text-xs text-slate-600">
        {total} señales detectadas en fuentes públicas
      </p>
    </div>
  </section>

  <!-- RESULTADOS DE BÚSQUEDA (oculto por defecto) -->
  <div id="search-results-area" class="hidden max-w-4xl mx-auto px-4 py-8 space-y-6">
    <div id="empty-results" class="hidden py-16 text-center">
      <p class="text-sm font-medium text-slate-400">No se encontraron casos para esa búsqueda.</p>
      <p class="text-xs mt-1 text-slate-600">Prueba con otros términos o consulta a un abogado especialista.</p>
    </div>
    <ol id="results-list" class="space-y-4"></ol>
    <div id="cta-abogado" class="hidden rounded-xl border border-amber-800/40 bg-amber-950/30 px-6 py-5">
      <p class="text-sm font-semibold text-amber-300 mb-1">¿Estás afrontando un proceso con incidencias?</p>
      <p class="text-xs text-slate-400 mb-3">
        Si has encontrado un caso similar al tuyo, un abogado especialista en contencioso-administrativo puede orientarte.
      </p>
      <a
        href={`mailto:josue@benchdatalab.com?subject=Consulta%20legal%20oposici%C3%B3n%20${encodeURIComponent(nicho.colectivo)}`}
        class="inline-flex items-center gap-2 text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors"
      >
        Solicitar información
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- CONTENIDO POR DEFECTO (oculto durante búsqueda activa) -->
  <div id="content-default">

    <!-- OBSERVATORIO JURÍDICO -->
    <section class="border-b border-slate-800/60 bg-slate-950">
      <div class="max-w-4xl mx-auto px-4 py-8">
        <div class="flex items-center justify-between mb-5">
          <div>
            <h2 class="text-sm font-semibold text-slate-200">Observatorio jurídico</h2>
            <p class="text-xs text-slate-500 mt-0.5">Incidencias con documentación oficial contrastada</p>
          </div>
          <a href="/incidencias" class="text-xs font-medium text-amber-400 hover:text-amber-300 transition-colors whitespace-nowrap">
            Ver todos →
          </a>
        </div>

        <!-- Stats clicables -->
        <div class="flex flex-wrap gap-3 mb-6">
          <a href="/casos/sentencias"
             class="flex items-center gap-2 rounded-lg border border-slate-800 bg-slate-900/40 px-3 py-2 hover:border-rose-800/60 transition-colors">
            <span class="text-lg font-extrabold text-rose-400 leading-none">{statsSentencias}</span>
            <span class="text-xs text-slate-500">Sentencias</span>
          </a>
          <a href="/casos/impugnaciones"
             class="flex items-center gap-2 rounded-lg border border-slate-800 bg-slate-900/40 px-3 py-2 hover:border-amber-800/60 transition-colors">
            <span class="text-lg font-extrabold text-amber-400 leading-none">{statsImpugnaciones}</span>
            <span class="text-xs text-slate-500">Impugnaciones</span>
          </a>
          <a href="/casos/anulaciones"
             class="flex items-center gap-2 rounded-lg border border-slate-800 bg-slate-900/40 px-3 py-2 hover:border-slate-700 transition-colors">
            <span class="text-lg font-extrabold text-slate-300 leading-none">{statsAnulaciones}</span>
            <span class="text-xs text-slate-500">Anulaciones</span>
          </a>
        </div>

        <!-- Incidencias verificadas -->
        <div class="grid sm:grid-cols-2 gap-3">
          {incidencias.slice(0, 4).map(inc => (
            <a
              href={`/incidencias/${inc.slug}`}
              class="rounded-lg border border-slate-800 bg-slate-900/60 p-4 hover:border-slate-700 transition-colors block"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full ring-1 text-amber-400 bg-amber-950/60 ring-amber-700/50">
                  {TIPO_INCIDENCIA[inc.tipo] ?? inc.tipo}
                </span>
                <time class="text-xs text-slate-600 ml-auto">{inc.fecha.slice(0, 4)}</time>
              </div>
              <p class="text-sm font-medium text-slate-200 leading-snug line-clamp-2">{inc.titulo}</p>
              <p class="text-xs text-slate-500 mt-1">{inc.organismo} · {inc.ubicacion}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- SEÑALES RECIENTES + SUGERENCIAS -->
    <div class="max-w-4xl mx-auto px-4 py-8">
      {error && (
        <div class="mb-6 rounded-lg bg-rose-950/60 border border-rose-800/60 px-4 py-3 text-rose-300 text-sm">
          ⚠ No se pudo conectar con la base de datos.
        </div>
      )}
      <p class="text-xs text-slate-500 mb-3">Búsquedas frecuentes:</p>
      <div class="flex flex-wrap gap-2 mb-8">
        {nicho.sugerencias.map(tag => (
          <button class="suggestion text-xs px-3 py-1.5 rounded-full border border-slate-700 text-slate-400
                         hover:border-amber-600 hover:text-amber-400 transition-colors bg-slate-900">
            {tag}
          </button>
        ))}
      </div>

      <p class="text-xs text-slate-500 mb-3">Señales recientes:</p>
      <ol class="space-y-4">
        {recientes.map(h => {
          const sm = sourceMeta(h.fuente)
          const fecha = h.fecha
            ? new Date(h.fecha).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })
            : null
          return (
            <li class="rounded-xl border border-slate-800 bg-slate-900/50 p-5 hover:border-slate-700 transition-colors">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class={`inline-flex items-center gap-1 text-[11px] font-semibold px-2 py-0.5 rounded-full ring-1 ${sm.color}`}>
                  {sm.icon} {sm.label}
                </span>
                {fecha && <time class="text-xs text-slate-500 ml-auto">{fecha}</time>}
              </div>
              <a href={`/hallazgos/${hallazgoSlug(h.titulo ?? '', h.id)}`}
                 class="block text-sm font-semibold text-slate-100 leading-snug mb-1 hover:text-amber-400 transition-colors">
                {h.titulo}
              </a>
              {h.descripcion && (
                <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">
                  {h.descripcion.slice(0, 200)}
                </p>
              )}
            </li>
          )
        })}
      </ol>
    </div>

    <!-- CTA B2B -->
    <div class="max-w-4xl mx-auto px-4 pb-10">
      <div class="rounded-xl border border-slate-700/50 bg-slate-900/40 px-6 py-5">
        <p class="text-sm font-semibold text-slate-300 mb-1">
          ¿Eres abogado, sindicato o academia?
        </p>
        <p class="text-xs text-slate-500 mb-3">
          Accede al informe semanal de señales jurídicas en formato CSV o resumen ejecutivo.
        </p>
        <a
          href="mailto:josue@benchdatalab.com?subject=Acceso%20informe%20profesional%20Radar%20Bomberos"
          class="inline-flex items-center gap-2 text-xs font-medium text-slate-400 hover:text-slate-200 transition-colors"
        >
          Solicitar acceso profesional
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>

  </div><!-- /content-default -->

  <!-- FOOTER -->
  <footer class="border-t border-slate-800/60">
    <div class="max-w-4xl mx-auto px-4 py-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-slate-600">
      <p>© {new Date().getFullYear()} {nicho.nombre} · Proyecto independiente</p>
      <nav class="flex flex-wrap gap-x-4 gap-y-1 justify-center">
        <a href="/oposiciones"          class="hover:text-slate-400 transition-colors">Oposiciones</a>
        <a href="/incidencias"         class="hover:text-slate-400 transition-colors">Observatorio</a>
        <a href="/origen-datos"        class="hover:text-slate-400 transition-colors">Fuentes</a>
        <a href="/aviso-legal"         class="hover:text-slate-400 transition-colors">Aviso legal</a>
        <a href="/politica-privacidad" class="hover:text-slate-400 transition-colors">Privacidad</a>
        <a href="/politica-cookies"    class="hover:text-slate-400 transition-colors">Cookies</a>
      </nav>
    </div>
  </footer>

  <!-- Datos embebidos para búsqueda cliente -->
  <script type="application/json" id="hallazgos-data" set:html={serialized}></script>

</Layout>

<script>
  const HALLAZGOS: Array<{
    slug: string; titulo: string; descripcion: string; fuente: string;
    fecha: string | null; url: string;
  }> = JSON.parse(document.getElementById('hallazgos-data')!.textContent ?? '[]')

  const SOURCE_COLOR: Record<string,string> = {
    'BOE':                     'text-amber-400 bg-amber-950/60 ring-amber-700/50',
    'CENDOJ':                  'text-rose-400 bg-rose-950/60 ring-rose-700/50',
    'CENDOJ (vía DuckDuckGo)': 'text-rose-400 bg-rose-950/60 ring-rose-700/50',
    'Google News':             'text-sky-400 bg-sky-950/60 ring-sky-700/50',
    'Google News (legal)':     'text-rose-400 bg-rose-950/60 ring-rose-700/50',
  }
  const SOURCE_ICON: Record<string,string> = {
    'BOE': '📋', 'CENDOJ': '⚖️', 'CENDOJ (vía DuckDuckGo)': '⚖️',
    'Google News': '📰', 'Google News (legal)': '⚖️',
  }
  const SOURCE_LABEL: Record<string,string> = {
    'BOE': 'Boletín oficial', 'CENDOJ': 'Sentencia',
    'CENDOJ (vía DuckDuckGo)': 'Sentencia', 'Google News': 'Prensa',
    'Google News (legal)': 'Sentencia',
  }

  function getSourceMeta(fuente: string) {
    if (fuente.startsWith('Reddit')) return {
      color: 'text-orange-400 bg-orange-950/60 ring-orange-700/50', icon: '💬', label: 'Foro',
    }
    return {
      color: SOURCE_COLOR[fuente] ?? 'text-slate-400 bg-slate-800 ring-slate-700/50',
      icon:  SOURCE_ICON[fuente]  ?? '🔗',
      label: SOURCE_LABEL[fuente] ?? fuente,
    }
  }

  function normalizar(s: string) {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '')
  }

  function fmtDate(d: string | null) {
    if (!d) return null
    return new Date(d).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })
  }

  function escapar(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')
  }

  function highlight(text: string, term: string) {
    if (!term) return escapar(text)
    const escaped = escapar(text)
    const safeRx  = term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
    return escaped.replace(
      new RegExp(`(${safeRx})`, 'gi'),
      '<mark class="bg-amber-500/30 text-amber-200 rounded px-0.5">$1</mark>'
    )
  }

  function renderCard(h: typeof HALLAZGOS[0], term: string) {
    const { color, icon, label } = getSourceMeta(h.fuente)
    const fecha  = fmtDate(h.fecha)
    const titulo = highlight(h.titulo, term)
    const desc   = h.descripcion ? highlight(h.descripcion.slice(0, 200), term) : ''
    return `<li class="rounded-xl border border-slate-800 bg-slate-900/50 p-5 hover:border-slate-700 transition-colors">
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <span class="inline-flex items-center gap-1 text-[11px] font-semibold px-2 py-0.5 rounded-full ring-1 ${color}">
          ${icon} ${label}
        </span>
        ${fecha ? `<time class="text-xs text-slate-500 ml-auto">${fecha}</time>` : ''}
      </div>
      <a href="/hallazgos/${h.slug}" class="block text-sm font-semibold text-slate-100 leading-snug mb-1 hover:text-amber-400 transition-colors">${titulo}</a>
      ${desc ? `<p class="text-xs text-slate-500 leading-relaxed line-clamp-2 mb-2">${desc}</p>` : ''}
      ${h.url ? `<a href="${escapar(h.url)}" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1 text-xs text-amber-500 hover:text-amber-400 transition-colors font-medium">
        Ver fuente original
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>` : ''}
    </li>`
  }

  const input          = document.getElementById('search-input')       as HTMLInputElement
  const statsEl        = document.getElementById('search-stats')       as HTMLElement
  const searchArea     = document.getElementById('search-results-area') as HTMLElement
  const contentDefault = document.getElementById('content-default')    as HTMLElement
  const emptyResults   = document.getElementById('empty-results')      as HTMLElement
  const resultsList    = document.getElementById('results-list')       as HTMLElement
  const ctaAbogado     = document.getElementById('cta-abogado')        as HTMLElement

  function mostrar(matches: typeof HALLAZGOS, term: string) {
    if (matches.length === 0) {
      emptyResults.classList.remove('hidden')
      resultsList.innerHTML = ''
      ctaAbogado.classList.add('hidden')
      return
    }
    emptyResults.classList.add('hidden')
    ctaAbogado.classList.remove('hidden')
    resultsList.innerHTML = matches.map(h => renderCard(h, term)).join('')
  }

  function buscar(raw: string) {
    const term = normalizar(raw.trim())

    if (!term) {
      contentDefault.classList.remove('hidden')
      searchArea.classList.add('hidden')
      resultsList.innerHTML = ''
      statsEl.textContent = `${HALLAZGOS.length} señales detectadas en fuentes públicas`
      return
    }

    contentDefault.classList.add('hidden')
    searchArea.classList.remove('hidden')
    emptyResults.classList.add('hidden')

    const words   = term.split(/\s+/).filter(Boolean)
    const matches = HALLAZGOS.filter(h => {
      const hay = normalizar(`${h.titulo} ${h.descripcion} ${h.fuente}`)
      return words.every(w => hay.includes(w))
    })

    statsEl.textContent = matches.length === HALLAZGOS.length
      ? `${HALLAZGOS.length} señales detectadas en fuentes públicas`
      : `${matches.length} resultado${matches.length !== 1 ? 's' : ''} para "${raw.trim()}"`

    mostrar(matches, raw.trim())
  }

  input.addEventListener('keydown', e => { if (e.key === 'Enter') buscar(input.value) })
  document.getElementById('search-btn')!.addEventListener('click', () => buscar(input.value))
  input.addEventListener('input', e => { if (!(e as InputEvent).data) buscar(input.value) })

  document.querySelectorAll<HTMLButtonElement>('.suggestion').forEach(btn => {
    btn.addEventListener('click', () => {
      input.value = btn.textContent?.trim() ?? ''
      buscar(input.value)
      input.focus()
    })
  })
</script>
