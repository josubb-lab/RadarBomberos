---
import Layout from '../../layouts/Layout.astro'
import { createClient } from '@supabase/supabase-js'
import { nicho } from '../../lib/nicho'

export async function getStaticPaths() {
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_KEY,
  )

  const { data: procesos = [] } = await supabase
    .from('procesos_selectivos')
    .select(`
      slug, organismo, comunidad, provincia, municipio,
      cuerpo, plazas, estado, fecha_pub, fecha_fin_inst,
      url_oficial, descripcion,
      senales_proceso(tipo, titulo, fecha, url, fuente)
    `)
    .eq('nicho', 'bomberos')

  return (procesos ?? []).map(p => ({
    params: { slug: p.slug },
    props:  { proceso: p },
  }))
}

const { proceso: p } = Astro.props

const ESTADO_META: Record<string, { label: string; color: string }> = {
  abierto:    { label: 'Abierto',    color: 'text-sky-400 bg-sky-950/60 ring-sky-700/50'      },
  activo:     { label: 'Activo',     color: 'text-slate-300 bg-slate-800/80 ring-slate-700/50' },
  impugnado:  { label: 'Impugnado',  color: 'text-amber-400 bg-amber-950/60 ring-amber-700/50' },
  suspendido: { label: 'Suspendido', color: 'text-slate-400 bg-slate-800/60 ring-slate-600/50' },
  cerrado:    { label: 'Cerrado',    color: 'text-slate-500 bg-slate-800/40 ring-slate-700/40' },
  anulado:    { label: 'Anulado',    color: 'text-rose-400 bg-rose-950/60 ring-rose-700/50'    },
}

const SENAL_META: Record<string, { label: string; color: string }> = {
  convocatoria: { label: 'Convocatoria', color: 'text-sky-400 bg-sky-950/60 ring-sky-700/50'      },
  correccion:   { label: 'Corrección',   color: 'text-amber-400 bg-amber-950/60 ring-amber-700/50' },
  impugnacion:  { label: 'Impugnación',  color: 'text-slate-300 bg-slate-800/60 ring-slate-600/50' },
  sentencia:    { label: 'Sentencia',    color: 'text-rose-400 bg-rose-950/60 ring-rose-700/50'    },
  anulacion:    { label: 'Anulación',    color: 'text-rose-400 bg-rose-950/60 ring-rose-700/50'    },
  recurso:      { label: 'Recurso',      color: 'text-slate-400 bg-slate-800/60 ring-slate-600/50' },
  suspension:   { label: 'Suspensión',   color: 'text-slate-400 bg-slate-800/60 ring-slate-600/50' },
}

const em     = ESTADO_META[p.estado] ?? { label: p.estado, color: 'text-slate-400 bg-slate-800 ring-slate-700/50' }
const lugar  = [p.municipio, p.provincia, p.comunidad].filter(Boolean).join(', ')
const senales = p.senales_proceso ?? []

const pageTitle = `${p.organismo} — ${p.cuerpo}${p.plazas ? ` · ${p.plazas} plazas` : ''} · ${nicho.nombre}`
const pageDesc  = p.descripcion ?? ''

const jsonLd = {
  '@context':  'https://schema.org',
  '@type':     'WebPage',
  name:         pageTitle,
  description:  pageDesc,
  url:          `${nicho.siteUrl}/procesos/${p.slug}`,
  inLanguage:   'es',
  isPartOf:     { '@type': 'WebSite', url: nicho.siteUrl },
  about: {
    '@type':    'GovernmentService',
    name:       `${p.cuerpo} — ${p.organismo}`,
    provider:   { '@type': 'GovernmentOrganization', name: p.organismo },
    areaServed: lugar,
  },
}

function isInternal(url: string | null): boolean {
  return url !== null && url.startsWith('/')
}
---

<Layout title={pageTitle} description={pageDesc} {jsonLd} canonical={`${nicho.siteUrl}/procesos/${p.slug}`}>

  <!-- NAV -->
  <nav class="border-b border-slate-800 bg-slate-950/90 backdrop-blur sticky top-0 z-40">
    <div class="max-w-4xl mx-auto px-4 h-14 flex items-center gap-3">
      <a href="/procesos" class="flex items-center gap-2 text-slate-400 hover:text-slate-100 transition-colors text-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Procesos selectivos
      </a>
      <span class="text-slate-700">/</span>
      <span class="text-slate-500 text-sm truncate max-w-[180px]">{p.municipio ?? p.provincia}</span>
    </div>
  </nav>

  <!-- HEADER -->
  <header class="bg-gradient-to-b from-slate-900 to-slate-950 border-b border-slate-800/60">
    <div class="max-w-4xl mx-auto px-4 py-10">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class={`inline-flex items-center text-[11px] font-semibold px-2 py-0.5 rounded-full ring-1 ${em.color}`}>
          {em.label}
        </span>
        {senales.length > 0 && (
          <span class="inline-flex items-center text-[11px] font-medium px-2 py-0.5 rounded-full ring-1 text-slate-400 bg-slate-800/60 ring-slate-700/50">
            Con señales
          </span>
        )}
      </div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-50 leading-tight mb-2">
        {p.organismo}
      </h1>
      <p class="text-slate-400 text-sm mb-4">
        {p.cuerpo}{p.plazas ? ` · ${p.plazas} plazas` : ''} · {lugar}
      </p>
      <p class="text-slate-400 text-sm max-w-2xl leading-relaxed">
        {p.descripcion}
      </p>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-10 space-y-10">

    <!-- DATOS DEL PROCESO -->
    <section>
      <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-4">Datos del proceso</h2>
      <dl class="grid sm:grid-cols-2 gap-3">
        {p.plazas && (
          <div class="rounded-lg border border-slate-800 bg-slate-900/50 px-4 py-3">
            <dt class="text-xs text-slate-600 mb-0.5">Plazas</dt>
            <dd class="text-sm font-semibold text-slate-200">{p.plazas}</dd>
          </div>
        )}
        {p.fecha_pub && (
          <div class="rounded-lg border border-slate-800 bg-slate-900/50 px-4 py-3">
            <dt class="text-xs text-slate-600 mb-0.5">Publicación</dt>
            <dd class="text-sm font-semibold text-slate-200">
              <time datetime={p.fecha_pub}>
                {new Date(p.fecha_pub).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })}
              </time>
            </dd>
          </div>
        )}
        {p.fecha_fin_inst && (
          <div class="rounded-lg border border-slate-800 bg-slate-900/50 px-4 py-3">
            <dt class="text-xs text-slate-600 mb-0.5">Fin plazo instancias</dt>
            <dd class="text-sm font-semibold text-slate-200">
              <time datetime={p.fecha_fin_inst}>
                {new Date(p.fecha_fin_inst).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })}
              </time>
            </dd>
          </div>
        )}
        {p.url_oficial && (
          <div class="rounded-lg border border-slate-800 bg-slate-900/50 px-4 py-3">
            <dt class="text-xs text-slate-600 mb-0.5">Documento oficial</dt>
            <dd class="text-sm">
              <a href={p.url_oficial} target="_blank" rel="noopener noreferrer"
                 class="text-amber-400 hover:text-amber-300 transition-colors">
                Ver publicación →
              </a>
            </dd>
          </div>
        )}
      </dl>
    </section>

    <!-- SEÑALES ASOCIADAS -->
    {senales.length > 0 && (
      <section>
        <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-4">
          Señales asociadas
        </h2>
        <ol class="space-y-3">
          {senales.map(s => {
            const sm    = SENAL_META[s.tipo] ?? { label: s.tipo, color: 'text-slate-400 bg-slate-800 ring-slate-700/50' }
            const fecha = s.fecha
              ? new Date(s.fecha).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })
              : null
            return (
              <li class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span class={`inline-flex items-center text-[11px] font-semibold px-2 py-0.5 rounded-full ring-1 ${sm.color}`}>
                    {sm.label}
                  </span>
                  <span class="text-xs text-slate-600">{s.fuente}</span>
                  {fecha && <time class="text-xs text-slate-500 ml-auto">{fecha}</time>}
                </div>
                {s.url ? (
                  <a
                    href={s.url}
                    target={isInternal(s.url) ? '_self' : '_blank'}
                    rel={isInternal(s.url) ? undefined : 'noopener noreferrer'}
                    class="block text-sm font-semibold text-slate-100 leading-snug hover:text-amber-400 transition-colors"
                  >
                    {s.titulo}
                  </a>
                ) : (
                  <p class="text-sm font-semibold text-slate-100 leading-snug">{s.titulo}</p>
                )}
              </li>
            )
          })}
        </ol>
      </section>
    )}

    <!-- CTA según estado -->
    {(p.estado === 'impugnado' || p.estado === 'anulado' || p.estado === 'suspendido') ? (
      <section class="rounded-xl border border-slate-700/50 bg-slate-900/40 px-6 py-5">
        <p class="text-sm font-semibold text-slate-300 mb-1">¿Estás afectado por este proceso?</p>
        <p class="text-xs text-slate-500 mb-3">
          Si participas o has participado en este proceso selectivo y quieres información sobre los recursos disponibles, un especialista en contencioso-administrativo puede orientarte.
        </p>
        <a
          href={`mailto:josue@benchdatalab.com?subject=Consulta%20proceso%20selectivo%20${encodeURIComponent(p.organismo)}`}
          class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors"
        >
          Consultar →
        </a>
      </section>
    ) : (
      <section class="rounded-xl border border-slate-700/50 bg-slate-900/40 px-6 py-5">
        <p class="text-sm font-semibold text-slate-300 mb-1">¿Preparas esta oposición?</p>
        <p class="text-xs text-slate-500 mb-3">
          Conocer los precedentes documentados ayuda a entender el proceso. Consulta el buscador completo para más señales relacionadas.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors"
        >
          Buscar en el observatorio →
        </a>
      </section>
    )}

  </main>

  <!-- FOOTER -->
  <footer class="border-t border-slate-800/60 mt-10">
    <div class="max-w-4xl mx-auto px-4 py-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-slate-600">
      <p>© {new Date().getFullYear()} {nicho.nombre} · Proyecto independiente</p>
      <nav class="flex gap-4">
        <a href="/aviso-legal"         class="hover:text-slate-400 transition-colors">Aviso legal</a>
        <a href="/politica-privacidad" class="hover:text-slate-400 transition-colors">Privacidad</a>
        <a href="/politica-cookies"    class="hover:text-slate-400 transition-colors">Cookies</a>
      </nav>
    </div>
  </footer>

</Layout>
