---
import Layout from '../../layouts/Layout.astro'
import { nicho } from '../../lib/nicho'
import { cuerpos } from '../../data/cuerpos-bomberos'

export function getStaticPaths() {
  return cuerpos.map(c => ({
    params: { slug: c.slug },
    props:  { cuerpo: c },
  }))
}

const { cuerpo: c } = Astro.props

const pageTitle = `${c.nombre} — Requisitos, Temario, Academias y Convocatorias`
const pageDesc  = `${c.descripcion} Requisitos de acceso, fases del proceso selectivo, temario y academias de oposiciones a bombero en ${c.ciudad}.`

const jsonLd = {
  '@context':   'https://schema.org',
  '@type':      'WebPage',
  name:          pageTitle,
  description:   pageDesc,
  url:           `${nicho.siteUrl}/oposiciones/${c.slug}`,
  inLanguage:    'es',
  isPartOf:      { '@type': 'WebSite', url: nicho.siteUrl },
  about: {
    '@type':    'GovernmentService',
    name:       c.nombre,
    provider:   { '@type': 'GovernmentOrganization', name: c.organismo },
    areaServed: c.ciudad,
  },
}
---

<Layout title={pageTitle} description={pageDesc} {jsonLd} canonical={`${nicho.siteUrl}/oposiciones/${c.slug}`}>

  <!-- NAV -->
  <nav class="border-b border-slate-800 bg-slate-950/90 backdrop-blur sticky top-0 z-40">
    <div class="max-w-4xl mx-auto px-4 h-14 flex items-center gap-3">
      <a href="/oposiciones" class="flex items-center gap-2 text-slate-400 hover:text-slate-100 transition-colors text-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Oposiciones
      </a>
      <span class="text-slate-700">/</span>
      <span class="text-slate-500 text-sm truncate max-w-[200px]">{c.ciudad}</span>
    </div>
  </nav>

  <!-- HEADER -->
  <header class="bg-gradient-to-b from-slate-900 to-slate-950 border-b border-slate-800/60">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="inline-flex items-center text-[11px] font-semibold px-2 py-0.5 rounded-full ring-1 text-sky-400 bg-sky-950/60 ring-sky-700/50">
          Oposiciones
        </span>
        <span class="inline-flex items-center text-[11px] font-medium px-2 py-0.5 rounded-full ring-1 text-slate-400 bg-slate-800/60 ring-slate-700/50">
          {c.comunidad}
        </span>
      </div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-50 leading-tight mb-3">
        {c.nombre}
      </h1>
      <p class="text-slate-400 text-sm mb-2">{c.organismo} · {c.ciudad}</p>
      <p class="text-slate-400 text-sm max-w-2xl leading-relaxed">{c.intro}</p>

      <div class="flex flex-wrap gap-4 mt-6">
        <div class="rounded-lg border border-slate-800 bg-slate-900/60 px-4 py-3 min-w-[140px]">
          <p class="text-xs text-slate-600 mb-0.5">Plazas habituales</p>
          <p class="text-sm font-bold text-slate-200">{c.plazasHabituales}</p>
        </div>
        <div class="rounded-lg border border-slate-800 bg-slate-900/60 px-4 py-3 min-w-[140px]">
          <p class="text-xs text-slate-600 mb-0.5">Frecuencia</p>
          <p class="text-sm font-bold text-slate-200">{c.frecuencia}</p>
        </div>
      </div>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-10 space-y-12">

    <!-- REQUISITOS -->
    <section>
      <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-5">
        Requisitos de acceso
      </h2>
      <ul class="space-y-2 mb-4">
        {c.requisitos.map(r => (
          <li class="flex items-start gap-3 text-sm text-slate-300 leading-snug">
            <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            {r}
          </li>
        ))}
      </ul>
      <p class="text-xs text-slate-600 leading-relaxed border-l-2 border-slate-800 pl-3">
        {c.requisitosNota}
      </p>
    </section>

    <!-- FASES -->
    <section>
      <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-5">
        Proceso selectivo — Fases
      </h2>
      <ol class="space-y-3">
        {c.fases.map((f, i) => (
          <li class="flex gap-4 rounded-xl border border-slate-800 bg-slate-900/50 p-5">
            <span class="flex-shrink-0 w-7 h-7 rounded-full bg-slate-800 border border-slate-700 text-xs font-bold text-slate-400 flex items-center justify-center">
              {i + 1}
            </span>
            <div>
              <p class="text-sm font-semibold text-slate-200 mb-1">{f.nombre}</p>
              <p class="text-xs text-slate-500 leading-relaxed">{f.descripcion}</p>
            </div>
          </li>
        ))}
      </ol>
      <p class="text-xs text-slate-600 leading-relaxed border-l-2 border-slate-800 pl-3 mt-4">
        {c.fasesNota}
      </p>
    </section>

    <!-- TEMARIO -->
    <section>
      <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-5">
        Temario — Materias principales
      </h2>
      <ul class="grid sm:grid-cols-2 gap-2">
        {c.temario.map(t => (
          <li class="flex items-start gap-2.5 text-xs text-slate-400 leading-snug rounded-lg border border-slate-800/60 bg-slate-900/30 px-3 py-2.5">
            <span class="text-amber-600 mt-0.5 shrink-0">▸</span>
            {t}
          </li>
        ))}
      </ul>
    </section>

    <!-- ACADEMIAS -->
    <section>
      <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-1">
        Academias de oposiciones a bombero en {c.ciudad}
      </h2>
      <p class="text-xs text-slate-600 mb-5">
        Preparación específica para {c.organismo} y otros cuerpos de {c.comunidad}.
      </p>
      <div class="rounded-xl border border-dashed border-slate-700 bg-slate-900/30 px-6 py-8 text-center">
        <p class="text-sm text-slate-500 mb-1">Todavía no hay academias verificadas para este cuerpo.</p>
        <p class="text-xs text-slate-600 mb-5">
          Si preparas oposiciones a bombero en {c.ciudad} y quieres aparecer aquí, escríbenos.
        </p>
        <a
          href={`mailto:josue@benchdatalab.com?subject=${encodeURIComponent(`Academia oposiciones bomberos — ${c.ciudad}`)}&body=${encodeURIComponent(`Hola,\n\nSomos una academia que prepara oposiciones a bombero en ${c.ciudad} y nos gustaría aparecer en la ficha de ${c.nombre}.\n\nNombre de la academia:\nWeb:\nTeléfono de contacto:\n`)}`}
          class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors"
        >
          Solicitar inclusión →
        </a>
      </div>
    </section>

    <!-- LEAD + BOE ALERTA -->
    <section id="alerta" class="rounded-xl border border-slate-700/50 bg-slate-900/50 px-6 py-7 space-y-6">

      <!-- Lead -->
      <div class="flex flex-col sm:flex-row sm:items-start gap-5">
        <div class="flex-1">
          <p class="text-slate-400 text-xs font-semibold uppercase tracking-widest mb-2">Mantente informado</p>
          <h3 class="text-base font-bold text-slate-100 mb-2">
            Novedades sobre oposiciones a bombero en {c.ciudad}
          </h3>
          <p class="text-xs text-slate-500 leading-relaxed max-w-md">
            Déjanos tu contacto y te avisamos si publicamos contenido nuevo sobre {c.organismo}: análisis de convocatorias, señales jurídicas o cambios relevantes en el proceso.
          </p>
        </div>
        <form
          class="flex flex-col gap-3 w-full sm:w-72 shrink-0"
          action="https://formsubmit.co/josue@benchdatalab.com"
          method="POST"
        >
          <input type="hidden" name="cuerpo"   value={c.nombre} />
          <input type="hidden" name="ciudad"   value={c.ciudad} />
          <input type="hidden" name="_subject" value={`Contacto oposiciones — ${c.ciudad}`} />
          <input type="hidden" name="_next"    value="https://firefighter.es/oposiciones/gracias" />
          <input type="hidden" name="_captcha" value="false" />
          <input
            type="email"
            name="email"
            required
            placeholder="tu@email.com"
            class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-slate-500 focus:ring-1 focus:ring-slate-500/30 transition"
          />
          <button
            type="submit"
            class="w-full rounded-lg border border-slate-600 bg-slate-800 hover:bg-slate-700 text-slate-200 text-sm font-semibold py-2.5 transition-colors"
          >
            Enviar
          </button>
          <p class="text-[10px] text-slate-700 text-center">
            <a href="/politica-privacidad" class="underline hover:text-slate-500">Política de privacidad</a>
          </p>
        </form>
      </div>

      <!-- Separador -->
      <div class="border-t border-slate-800"></div>

      <!-- BOE alerta -->
      <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex-1">
          <p class="text-xs font-semibold text-amber-400 mb-1">Alerta directa del BOE</p>
          <p class="text-xs text-slate-500 leading-relaxed">
            Para recibir un aviso automático cada vez que el BOE publique una convocatoria de bombero, configura una alerta gratuita en el buscador oficial. Es la fuente más fiable y no depende de intermediarios.
          </p>
        </div>
        <a
          href={`https://www.boe.es/buscar/alertas_boe.php?campo%5B1%5D=TITULOS&dato%5B1%5D=${encodeURIComponent('bombero proceso selectivo ' + c.ciudad)}&accion=Buscar`}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 inline-flex items-center gap-2 rounded-lg border border-amber-700/40 bg-amber-950/30 px-4 py-2.5 text-xs font-semibold text-amber-400 hover:bg-amber-950/50 transition-colors whitespace-nowrap"
        >
          Configurar alerta en el BOE
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>

    </section>

    <!-- OBSERVATORIO -->
    <section class="rounded-xl border border-slate-800 bg-slate-900/40 px-6 py-5">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Observatorio jurídico</p>
      <p class="text-sm font-semibold text-slate-300 mb-1">¿Ha habido impugnaciones en este proceso?</p>
      <p class="text-xs text-slate-500 mb-4 leading-relaxed">
        Monitorizamos sentencias, impugnaciones y anomalías documentadas en procesos selectivos de bomberos en España. Consulta si existe algún precedente relacionado con {c.organismo}.
      </p>
      <a
        href={`/?q=${encodeURIComponent(c.ciudad)}`}
        class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors"
      >
        Buscar en el observatorio →
      </a>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="border-t border-slate-800/60 mt-10">
    <div class="max-w-4xl mx-auto px-4 py-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-slate-600">
      <p>© {new Date().getFullYear()} {nicho.nombre} · Proyecto independiente</p>
      <nav class="flex gap-4">
        <a href="/aviso-legal"         class="hover:text-slate-400 transition-colors">Aviso legal</a>
        <a href="/politica-privacidad" class="hover:text-slate-400 transition-colors">Privacidad</a>
        <a href="/politica-cookies"    class="hover:text-slate-400 transition-colors">Cookies</a>
      </nav>
    </div>
  </footer>

</Layout>
