---
import Layout from '../../layouts/Layout.astro'
import { nicho } from '../../lib/nicho'
import { cuerpos } from '../../data/cuerpos-bomberos'

const pageTitle = 'Oposiciones a Bombero en España — Convocatorias por comunidad y ciudad'
const pageDesc  = 'Guía completa de oposiciones a bombero en España. Requisitos, temario, pruebas físicas y convocatorias por ciudad y comunidad autónoma.'

const jsonLd = {
  '@context':    'https://schema.org',
  '@type':       'CollectionPage',
  name:          pageTitle,
  description:   pageDesc,
  url:           `${nicho.siteUrl}/oposiciones`,
  inLanguage:    'es',
  isPartOf:      { '@type': 'WebSite', url: nicho.siteUrl },
  numberOfItems: cuerpos.length,
}
---

<Layout title={pageTitle} description={pageDesc} {jsonLd} canonical={`${nicho.siteUrl}/oposiciones`}>

  <!-- NAV -->
  <nav class="border-b border-slate-800 bg-slate-950/90 backdrop-blur sticky top-0 z-40">
    <div class="max-w-5xl mx-auto px-4 h-14 flex items-center gap-3">
      <a href="/" class="flex items-center gap-2 text-slate-400 hover:text-slate-100 transition-colors text-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        {nicho.nombre}
      </a>
      <span class="text-slate-700">/</span>
      <span class="text-slate-500 text-sm">Oposiciones</span>
    </div>
  </nav>

  <!-- HEADER -->
  <header class="bg-gradient-to-b from-slate-900 to-slate-950 border-b border-slate-800/60">
    <div class="max-w-5xl mx-auto px-4 py-12">
      <p class="text-amber-500 text-xs font-semibold uppercase tracking-widest mb-3">
        Guía de oposiciones
      </p>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-50 leading-tight mb-4">
        Oposiciones a Bombero en España
      </h1>
      <p class="text-slate-400 text-base max-w-2xl leading-relaxed">
        Requisitos, temario, pruebas físicas y convocatorias de los {cuerpos.length} cuerpos de bomberos más importantes de España.
        Selecciona tu ciudad o comunidad para ver la guía completa.
      </p>
    </div>
  </header>

  <!-- GRID -->
  <main class="max-w-5xl mx-auto px-4 py-10">
    <ol class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {cuerpos.map(c => (
        <li>
          <a
            href={`/oposiciones/${c.slug}`}
            class="flex flex-col h-full rounded-xl border border-slate-800 bg-slate-900/50 p-5 hover:border-amber-600/50 hover:bg-slate-900 transition-colors group"
          >
            <div class="flex items-start justify-between gap-2 mb-3">
              <span class="text-xs font-medium text-slate-500 leading-snug">{c.comunidad}</span>
              <svg class="w-4 h-4 text-slate-700 group-hover:text-amber-500 transition-colors shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
            <p class="text-sm font-bold text-slate-100 leading-snug mb-2 group-hover:text-amber-400 transition-colors">
              {c.nombre}
            </p>
            <p class="text-xs text-slate-500 leading-relaxed flex-1">
              {c.descripcion.slice(0, 100)}{c.descripcion.length > 100 ? '…' : ''}
            </p>
            <div class="mt-4 flex items-center gap-3 text-xs text-slate-600">
              <span>{c.plazasHabituales}</span>
              <span class="text-slate-800">·</span>
              <span>{c.frecuencia}</span>
            </div>
          </a>
        </li>
      ))}
    </ol>

    <!-- CTA -->
    <div class="mt-14 rounded-xl border border-amber-800/30 bg-amber-950/20 px-6 py-6">
      <p class="text-sm font-semibold text-slate-200 mb-1">¿No encuentras tu ciudad?</p>
      <p class="text-xs text-slate-500 mb-4 max-w-lg">
        Cubrimos todos los cuerpos de bomberos de España. Si quieres recibir alertas cuando se convoque una plaza en tu zona, déjanos tu contacto.
      </p>
      <a
        href="/#alerta"
        class="inline-flex items-center gap-1.5 text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors"
      >
        Recibir alertas de convocatorias
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="border-t border-slate-800/60 mt-10">
    <div class="max-w-5xl mx-auto px-4 py-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-slate-600">
      <p>© {new Date().getFullYear()} {nicho.nombre} · Proyecto independiente</p>
      <nav class="flex gap-4">
        <a href="/aviso-legal"         class="hover:text-slate-400 transition-colors">Aviso legal</a>
        <a href="/politica-privacidad" class="hover:text-slate-400 transition-colors">Privacidad</a>
        <a href="/politica-cookies"    class="hover:text-slate-400 transition-colors">Cookies</a>
      </nav>
    </div>
  </footer>

</Layout>
